# ══════════════════════════════════════════════════════
#  Stitch & Smile Studio — Environment Variables
#  Copy this file to ".env" and fill in your real values
# ══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
PORT=3000

# Your live site URL (used in emails) — set after you deploy to Railway
SITE_URL=https://your-railway-app.railway.app

# ── Security ────────────────────────────────────────────
# Generate a random secret: open Terminal and run:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Stripe ──────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use "Test" keys while testing, "Live" keys when ready to sell for real
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get this after setting up your Stripe webhook (see SETUP_GUIDE.md)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SendGrid ────────────────────────────────────────────
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address your shop sends FROM (must be verified in SendGrid)
SHOP_EMAIL=hello@stitchandsmile.com

# ── Shop Settings ───────────────────────────────────────
SHOP_NAME=Stitch & Smile Studio
DRIVE_SHIP_COST=4.99
